#!/usr/bin/env node

const JSONTree = require('..');

try {
  const tree = new JSONTree(process.cwd());

  if (process.env.DEBUG === 'true') {
    console.log(tree.schema); // eslint-disable-line no-console
  } else if (tree.schema) {
    const output = [
      JSON.stringify(tree.schema),
      '',
      `Copy JSON above, then paste it there: ${JSONTree.getImportLink()}`,
      '',
    ].join('\n');

    process.stdout.write(output, () => process.exit());
  }
} catch (e) {
  process.stderr.write(`Error: ${e.message}\n`);
  process.exit(1);
}
